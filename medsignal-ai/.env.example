# PostgreSQL
POSTGRES_USER=medsignal
POSTGRES_PASSWORD=medsignal
POSTGRES_DB=medsignal

# Backend
# Docker Compose uses postgres as the database host.
DOCKER_DATABASE_URL=postgresql+psycopg2://medsignal:medsignal@postgres:5432/medsignal
# Use localhost if you run the backend directly on your host machine.
DATABASE_URL=postgresql+psycopg2://medsignal:medsignal@localhost:5432/medsignal
ENVIRONMENT=local
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov
RXNORM_TIMEOUT_SECONDS=5
OPENFDA_BASE_URL=https://api.fda.gov
OPENFDA_TIMEOUT_SECONDS=10

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# MLflow
DOCKER_MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=medsignal-label-summarization

# Hugging Face summarizer
SUMMARIZER_MODEL_NAME=sshleifer/distilbart-cnn-6-6
SUMMARIZER_TASK=summarization
SUMMARIZER_MAX_INPUT_CHARS=4000
SUMMARIZER_MAX_NEW_TOKENS=180
SUMMARIZER_MIN_NEW_TOKENS=60
